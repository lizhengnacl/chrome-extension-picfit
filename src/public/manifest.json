{
  "manifest_version": 3,
  "name": "图适配 (PicFit)",
  "version": "1.0.0",
  "description": "PicFit 图适配 - 快速满足各种平台上传图片时的尺寸、大小、格式要求",
  "permissions": [
    "storage",
    "downloads"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}

